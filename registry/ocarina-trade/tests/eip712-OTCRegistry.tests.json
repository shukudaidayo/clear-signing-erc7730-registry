{
  "$schema": "../../../specs/erc7730-tests.schema.json",
  "tests": [
    {
      "description": "Authorize a real mainnet Ocarina offer registration",
      "data": {
        "types": {
          "OrderRegistration": [
            { "name": "orderHash", "type": "bytes32" },
            { "name": "seaportSignature", "type": "bytes" },
            { "name": "memo", "type": "string" }
          ],
          "EIP712Domain": [
            { "name": "name", "type": "string" },
            { "name": "version", "type": "string" },
            { "name": "chainId", "type": "uint256" },
            { "name": "verifyingContract", "type": "address" }
          ]
        },
        "domain": {
          "name": "OTCRegistry",
          "version": "1",
          "chainId": "0x1",
          "verifyingContract": "0x07c0000007b4b558e2fcd47f47a573413b0caf7c"
        },
        "primaryType": "OrderRegistration",
        "message": {
          "orderHash": "0xf75521532f2e847360ad8aef8ad399d789f3c2355b380a43ed0d298b49d4b198",
          "seaportSignature": "0x1eb115c809a09b20482c50d0d45e6fdb44ec68c5d43a3a8d99d457786e1cf198f86113f3d027c027407a15bfe245a5259ff6b5eb1e474abe4b790bf8a593a40a",
          "memo": "Test"
        }
      },
      "expectedTexts": ["Authorize offer", "Order hash", "0xf75521532f2e847360ad8aef8ad399d789f3c2355b380a43ed0d298b49d4b198", "Memo", "Test"]
    },
